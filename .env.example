# Database
DB_DRIVER=sqlite
DB_HOST=db
DB_NAME=epiella
DB_USER=epiella
DB_PASS=secret
DB_PORT=3306

# SQLite file path (resolved relative to repo root when not absolute)
# Docker Compose:
SQLITE_PATH=/var/data/epiella.sqlite
# Native dev (start-dev.bat / start-dev.sh) — uncomment and comment Docker line above:
# SQLITE_PATH=data/epiella.sqlite

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=2592000

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=http://localhost:8080

# Seed admin user — run after: php scripts/migrate.php apply && php scripts/seed.php
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=changeme

# Frontend build (empty = same origin; set for split deploy)
VITE_API_BASE=
