{
  "name": "epiella/api",
  "description": "EpiElla API — Epiphany + JWT auth",
  "type": "project",
  "require": {
    "php": ">=8.3",
    "firebase/php-jwt": "^6.10"
  },
  "autoload": {
    "classmap": [
      "lib/",
      "controllers/"
    ]
  },
  "config": {
    "vendor-dir": "vendor/composer",
    "audit": {
      "block-insecure": false
    }
  }
}
